# Local Mac delivery (iMessage via AppleScript)
ULTRAPLAN_PHONE=+15551234567
ULTRAPLAN_EMAIL=you@example.com

# Cloud delivery (ntfy.sh push notifications — works from GitHub Actions)
# Pick any unique topic name. Install ntfy app on iPhone, subscribe to this topic.
ULTRAPLAN_NTFY_TOPIC=ultraplan-yourname-random

# Delivery mode: "ntfy", "imessage", or "both"
ULTRAPLAN_DELIVERY=both
